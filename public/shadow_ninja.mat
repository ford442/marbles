material {
    name : "Shadow Ninja Material",
    parameters : [
        { type : float3, name : baseColor },
        { type : float,  name : roughness },
        { type : float,  name : metallic },
        { type : float,  name : reflectance },
        { type : float,  name : clearCoat },
        { type : float,  name : clearCoatRoughness },
        { type : float,  name : bumpScale },
        { type : float,  name : bumpFrequency },
        { type : float,  name : voidAbsorption },
        { type : float,  name : smokeIntensity },
        { type : float,  name : shadowSpeed }
    ],
    requires : [ uv0, tangents ],
    shadingModel : lit,
    blending : opaque,
    specularAntiAliasing : true,
    specularAntiAliasingVariance : 0.15,
    specularAntiAliasingThreshold : 0.2
}

fragment {
    // Simplex noise
    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

    float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                           -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v -   i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                               + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                               dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }

    float fbm(vec2 uv, float freq) {
        float f = 0.0;
        float w = 0.5;
        for (int i = 0; i < 4; i++) {
            f += w * snoise(uv * freq);
            freq *= 2.0;
            w *= 0.5;
        }
        return f;
    }

    // Multi-layered void darkness
    float voidNoise(vec3 pos, float time, float speed) {
        float noise = 0.0;
        float amplitude = 1.0;
        float frequency = 1.0;
        for (int i = 0; i < 6; i++) {
            vec3 p = pos * frequency + time * speed * float(i + 1);
            noise += sin(p.x) * cos(p.y) * sin(p.z) * amplitude;
            amplitude *= 0.5;
            frequency *= 2.5;
        }
        return noise * 0.5 + 0.5;
    }

    // Shadow tendril pattern
    float shadowTendrils(vec2 uv, vec3 worldPos, float time) {
        float tendrils = 0.0;
        vec2 p1 = uv * 6.0 + time * 0.3;
        float t1 = sin(p1.x + sin(p1.y * 2.0 + time * 0.5)) * 0.5 + 0.5;
        tendrils += smoothstep(0.6, 0.65, t1) * 0.7;

        vec2 p2 = uv * 10.0 - time * 0.2;
        float t2 = sin(p2.y + cos(p2.x * 1.5)) * 0.5 + 0.5;
        tendrils += smoothstep(0.7, 0.75, t2) * 0.4;

        float worldVar = sin(worldPos.x * 3.0 + worldPos.z * 2.0) * 0.3 + 0.7;
        return tendrils * worldVar;
    }

    // Smoke wisp overlay
    vec3 smokeWisps(vec2 uv, vec3 worldPos, float time, float intensity) {
        vec3 smoke = vec3(0.0);
        vec2 s1 = uv * 4.0 + vec2(time * 0.1, time * 0.15);
        float n1 = sin(s1.x * 3.0) * cos(s1.y * 2.0);
        n1 += sin(s1.x * 7.0 - time * 0.3) * 0.5;
        smoke += vec3(0.1, 0.05, 0.15) * (n1 * 0.5 + 0.5) * 0.4;

        vec2 s2 = uv * 8.0 + vec2(-time * 0.2, time * 0.1);
        float n2 = sin(s2.x * 5.0 + s2.y * 3.0) * sin(s2.y * 4.0);
        smoke += vec3(0.15, 0.08, 0.2) * (n2 * 0.5 + 0.5) * 0.3;

        return smoke * intensity;
    }

    // Purple rim light
    vec3 calculateRimLight(vec3 viewDir, vec3 normal, float time) {
        float fresnel = pow(1.0 - abs(dot(viewDir, normal)), 3.0);
        vec3 rimColor1 = vec3(0.6, 0.2, 0.9);
        vec3 rimColor2 = vec3(0.3, 0.1, 0.5);
        float angleVar = sin(atan(normal.y, normal.x) * 3.0 + time) * 0.5 + 0.5;
        vec3 rimColor = mix(rimColor1, rimColor2, angleVar);
        return rimColor * fresnel * 3.0;
    }

    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        float freq = materialParams.bumpFrequency;
        float scale = materialParams.bumpScale;
        float time = getTime();

        // Normal perturbation
        float noise = fbm(uv, freq);
        float noiseX = fbm(uv + vec2(0.01, 0.0), freq);
        float noiseY = fbm(uv + vec2(0.0, 0.01), freq);
        vec3 normalTangent;
        normalTangent.x = (noiseX - noise) * scale * 100.0;
        normalTangent.y = (noiseY - noise) * scale * 100.0;
        normalTangent.z = 1.0;
        normalTangent = normalize(normalTangent);
        material.normal = normalTangent;

        prepareMaterial(material);

        vec3 worldPos = getWorldPosition();
        vec3 viewDir = normalize(getWorldCameraPosition() - worldPos);
        vec3 normal = normalize(shading_normal);

        // Base void color - deep purple-black
        vec3 baseColor = materialParams.baseColor;

        // Void noise texture
        float voidTex = voidNoise(worldPos * 8.0, time * 0.3, materialParams.shadowSpeed);
        baseColor *= (0.7 + voidTex * 0.6);

        // Shadow tendrils
        float tendrils = shadowTendrils(uv, worldPos, time);
        vec3 tendrilColor = vec3(0.02, 0.01, 0.03) * tendrils;

        // Smoke wisps
        vec3 smoke = smokeWisps(uv, worldPos, time, materialParams.smokeIntensity);

        // Void absorption effect
        float absorption = voidTex * pow(1.0 - abs(dot(viewDir, normal)), 2.0) *
                           (sin(time * 1.5) * 0.2 + 0.8) * materialParams.voidAbsorption;

        // Purple rim light
        vec3 rimLight = calculateRimLight(viewDir, normal, time);

        // Emissive smoke glow
        float emissiveSmoke = voidNoise(worldPos * 4.0 + time * 0.5, time * 0.2, materialParams.shadowSpeed);
        vec3 emissiveColor = vec3(0.4, 0.1, 0.6) * emissiveSmoke * 0.5;

        // Combine all layers
        vec3 finalColor = baseColor;
        finalColor += tendrilColor;
        finalColor += smoke;
        finalColor += vec3(0.0) * absorption;
        finalColor += rimLight;
        finalColor += emissiveColor;

        // Edge darkening (void characteristic)
        float edgeDarken = pow(abs(dot(viewDir, normal)), 0.5);
        finalColor *= mix(0.3, 1.0, edgeDarken);

        // Emission from rim and smoke
        vec3 emission = rimLight * 0.8 + emissiveColor * 0.5;

        material.baseColor = vec4(finalColor, 1.0);
        material.roughness = materialParams.roughness + noise * 0.05;
        material.metallic = materialParams.metallic;
        material.reflectance = materialParams.reflectance;
        material.clearCoat = materialParams.clearCoat;
        material.clearCoatRoughness = materialParams.clearCoatRoughness;
        material.emissive = vec4(emission, 1.0);
        material.ambientOcclusion = clamp(1.0 - (abs(noise) * scale * 10.0), 0.5, 1.0);
    }
}
