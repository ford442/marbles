material {
    name : "Procedural Bump PBR Material",
    parameters : [
        { type : float3, name : baseColor },
        { type : float,  name : roughness },
        { type : float,  name : metallic },
        { type : float,  name : bumpScale },
        { type : float,  name : bumpFrequency },
        { type : float,  name : reflectance },
        { type : float,  name : clearCoat },
        { type : float,  name : clearCoatRoughness },
        { type : float3, name : emissive },
        { type : float,  name : emissiveIntensity },
        { type : float,  name : refractionMode },
        { type : float,  name : thickness },
        { type : float,  name : causticIntensity },
        { type : float,  name : chromaticDispersion },
        { type : float,  name : fresnelStrength },
        { type : float,  name : bumpOctaves },
        { type : float,  name : surfaceType },
        { type : float,  name : subsurfaceStrength },
        { type : float,  name : anisotropyStrength },
        { type : float,  name : grainScale },
        { type : float,  name : scratchesIntensity },
        { type : float,  name : iridescenceScale },
        { type : float,  name : effectTime },
        { type : float,  name : sparkleStrength },
        { type : float,  name : heatShimmer },
        { type : float,  name : environmentIntensity },
        { type : float,  name : reflectionStrength }
    ],
    requires : [ uv0, tangents ],
    shadingModel : lit,
    blending : opaque,
    specularAntiAliasing : true,
    specularAntiAliasingVariance : 0.15,
    specularAntiAliasingThreshold : 0.2
}

fragment {

    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

    float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                           -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v -   i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                               + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                               dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }

    float fbmOct(vec2 uv, float freq, float octaves) {
        float f = 0.0;
        float w = 0.5;
        for (int i = 0; i < 4; i++) {
            if (float(i) >= octaves) break;
            f += w * snoise(uv * freq);
            freq *= 2.0;
            w *= 0.5;
        }
        return f;
    }

    float triplanarFbm(vec3 wp, vec3 n, float freq, float octaves) {
        vec3 w = abs(n);
        w = max(w, vec3(0.001));
        w /= (w.x + w.y + w.z);
        return fbmOct(wp.zy, freq, octaves) * w.x
             + fbmOct(wp.xz, freq, octaves) * w.y
             + fbmOct(wp.xy, freq, octaves) * w.z;
    }

    void material(inout MaterialInputs material) {
        vec3 wp = getWorldPositionVector();
        vec3 wn = normalize(getWorldGeometricNormalVector());
        float freq = max(materialParams.bumpFrequency, 1.0);
        float scale = materialParams.bumpScale;
        float octaves = clamp(materialParams.bumpOctaves, 0.0, 4.0);
        float surf = materialParams.surfaceType;

        float noise = 0.0;
        if (octaves > 0.5 && scale > 0.0001) {
            noise = triplanarFbm(wp * 0.35, wn, freq, octaves);
        }

        // Surface-specific detail overlays (object-space, UV-less)
        if (surf > 0.5 && surf < 1.5) {
            // stoneVein — deep veins + multi-scale grain
            float veins = triplanarFbm(wp * 0.2 + vec3(0.0, wp.y * 0.05, 0.0), wn, freq * 0.6, octaves);
            noise = mix(noise, veins, 0.75);
            noise += triplanarFbm(wp * 0.8, wn, freq * 2.5, max(octaves - 1.0, 1.0)) * 0.25;
        } else if (surf > 1.5 && surf < 2.5) {
            // obsidian — sharp chips + scratches
            float grain = materialParams.grainScale;
            float chips = triplanarFbm(wp * (1.0 + grain * 0.08), wn, freq * 3.5, max(octaves, 1.0));
            float scratches = sin(wp.x * grain * 4.0 + wp.z * grain * 3.0) * materialParams.scratchesIntensity;
            noise = mix(noise, chips, 0.85) + scratches * 0.15;
        } else if (surf > 2.5 && surf < 3.5) {
            // volcanic — heat cracks
            float cracks = abs(sin(wp.x * 6.0 + noise * 4.0) * cos(wp.z * 5.0 + noise * 3.0));
            noise = mix(noise, cracks, 0.6);
        }

        float dNoiseX = triplanarFbm(wp * 0.35 + vec3(0.015, 0.0, 0.0), wn, freq, octaves) - noise;
        float dNoiseY = triplanarFbm(wp * 0.35 + vec3(0.0, 0.015, 0.0), wn, freq, octaves) - noise;
        float dNoiseZ = triplanarFbm(wp * 0.35 + vec3(0.0, 0.0, 0.015), wn, freq, octaves) - noise;

        vec3 normalTangent;
        normalTangent.x = dNoiseX * scale * 120.0;
        normalTangent.y = dNoiseY * scale * 120.0;
        normalTangent.z = 1.0;

        if (materialParams.heatShimmer > 0.001) {
            normalTangent.xy += vec2(
                sin(materialParams.effectTime * 3.0 + wp.x * 12.0),
                cos(materialParams.effectTime * 2.5 + wp.z * 11.0)
            ) * materialParams.heatShimmer;
        }

        normalTangent = normalize(normalTangent);
        material.normal = normalTangent;

        prepareMaterial(material);

        material.baseColor.rgb = materialParams.baseColor;
        material.baseColor.a = 1.0;
        material.roughness = clamp(materialParams.roughness + noise * 0.12, 0.0, 1.0);
        material.metallic = materialParams.metallic;
        material.reflectance = materialParams.reflectance * materialParams.reflectionStrength;
        material.clearCoat = materialParams.clearCoat;
        material.clearCoatRoughness = materialParams.clearCoatRoughness;
        material.emissive.rgb = materialParams.emissive * materialParams.emissiveIntensity;

        vec3 V = normalize(getWorldViewVector());
        vec3 N = normalize(getWorldNormalVector());
        float NdotV = clamp(abs(dot(N, V)), 0.0, 1.0);

        // Cheap wrap subsurface / translucency tint
        float wrap = clamp(dot(N, V) * 0.5 + 0.5, 0.0, 1.0);
        if (materialParams.subsurfaceStrength > 0.001) {
            vec3 sssTint = mix(material.baseColor.rgb, vec3(1.0, 0.85, 0.7), 0.35);
            material.baseColor.rgb = mix(material.baseColor.rgb, sssTint, materialParams.subsurfaceStrength * wrap * 0.45);
            material.roughness = mix(material.roughness, material.roughness * 0.85, materialParams.subsurfaceStrength * 0.3);
        }

        // Thin-film iridescence (neon / crystal / glass)
        if (materialParams.iridescenceScale > 0.001) {
            float iri = materialParams.iridescenceScale
                * (0.5 + 0.5 * sin(materialParams.effectTime * 0.6 + NdotV * 12.0));
            material.baseColor.rgb += iri * vec3(0.15, 0.35, 0.55) * (1.0 - NdotV);
        }

        // Glancing sparkle (neon / glass)
        if (materialParams.sparkleStrength > 0.001) {
            vec3 R = reflect(-V, N);
            float spec = pow(max(dot(R, normalize(vec3(0.3, 1.0, 0.2))), 0.0), 48.0);
            material.emissive.rgb += spec * materialParams.sparkleStrength * vec3(1.0, 0.95, 0.85);
        }

        if (materialParams.refractionMode > 0.5) {
            vec2 uv = getUV0();
            float causticPhase = sin(uv.x * 8.0 + uv.y * 8.0 + noise * 2.0) * 0.5 + 0.5;
            float causticPattern = causticPhase * (1.0 - materialParams.thickness);
            causticPattern *= materialParams.causticIntensity;

            float fresnel = mix(0.04, 1.0, pow(1.0 - NdotV, 5.0));
            fresnel *= materialParams.fresnelStrength;

            material.baseColor.rgb *= 1.0 + causticPattern;
            material.baseColor.rgb += fresnel * vec3(0.35, 0.4, 0.65) * materialParams.environmentIntensity;

            if (materialParams.refractionMode > 1.5) {
                float dispersion = materialParams.chromaticDispersion * 0.025;
                material.baseColor.r *= 1.0 + dispersion;
                material.baseColor.b *= 1.0 - dispersion;
            }

            material.roughness = mix(material.roughness, 0.01, fresnel * 0.35);
        }

        material.ambientOcclusion = clamp(1.0 - (abs(noise) * scale * 12.0), 0.45, 1.0);
        material.anisotropy = materialParams.anisotropyStrength * noise;
    }
}
