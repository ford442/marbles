material {
    name : "Procedural Bump PBR Material",
    parameters : [
        {
           type : float3,
           name : baseColor
        },
        {
           type : float,
           name : roughness
        },
        {
           type : float,
           name : metallic
        },
        {
           type : float,
           name : bumpScale
        },
        {
           type : float,
           name : bumpFrequency
        },
        {
           type : float,
           name : reflectance
        },
        {
           type : float,
           name : clearCoat
        },
        {
           type : float,
           name : clearCoatRoughness
        },
        {
           type : float3,
           name : emissive
        },
        {
           type : float,
           name : emissiveIntensity
        },
        {
           type : float,
           name : refractionMode
        },
        {
           type : float,
           name : thickness
        },
        {
           type : float,
           name : causticIntensity
        },
        {
           type : float,
           name : chromaticDispersion
        },
        {
           type : float,
           name : fresnelStrength
        }
    ],
    requires : [ uv0, tangents ],
    shadingModel : lit,
    blending : opaque,
    specularAntiAliasing : true,
    specularAntiAliasingVariance : 0.15,
    specularAntiAliasingThreshold : 0.2
}

fragment {
    
    // Simplex noise function for procedural bump
    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }
    
    float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                           -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v -   i + dot(i, C.xx);
        vec2 i1;
        i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                               + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                               dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }

    // Fractal Brownian Motion for more organic details
    float fbm(vec2 uv, float freq) {
        float f = 0.0;
        float w = 0.5;
        for (int i = 0; i < 4; i++) {
            f += w * snoise(uv * freq);
            freq *= 2.0;
            w *= 0.5;
        }
        return f;
    }
    
    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        float freq = materialParams.bumpFrequency;
        float scale = materialParams.bumpScale;
        
        // Calculate procedural normal perturbation using noise
        // Enhance with FBM to create more organic and detailed surfaces
        float noise = fbm(uv, freq);
        float noiseX = fbm(uv + vec2(0.01, 0.0), freq);
        float noiseY = fbm(uv + vec2(0.0, 0.01), freq);
        
        vec3 normalTangent;
        normalTangent.x = (noiseX - noise) * scale * 100.0;
        normalTangent.y = (noiseY - noise) * scale * 100.0;
        normalTangent.z = 1.0;
        normalTangent = normalize(normalTangent);
        
        material.normal = normalTangent;
        
        // Prepare material
        prepareMaterial(material);
        
        // Base PBR properties
        material.baseColor.rgb = materialParams.baseColor;
        material.baseColor.a = 1.0;

        // Slightly vary roughness based on bump noise for more realism
        material.roughness = clamp(materialParams.roughness + noise * 0.1, 0.0, 1.0);

        material.metallic = materialParams.metallic;
        material.reflectance = materialParams.reflectance;
        material.clearCoat = materialParams.clearCoat;
        material.clearCoatRoughness = materialParams.clearCoatRoughness;
        
        // Emissive — self-illuminated marbles for bloom effects
        material.emissive.rgb = materialParams.emissive * materialParams.emissiveIntensity;
        
        // Glass-specific refractive effects
        // refractionMode: 0 = off, 1 = fake caustics only, 2 = full refraction + caustics
        if (materialParams.refractionMode > 0.5) {
            // Generate caustics pattern: thickness-modulated sine wave
            float causticPhase = sin(uv.x * 8.0 + uv.y * 8.0 + material.normal.x * 2.0) * 0.5 + 0.5;
            float causticPattern = causticPhase * (1.0 - materialParams.thickness);
            causticPattern *= materialParams.causticIntensity;
            
            // Fresnel effect: stronger at edges
            float NdotV = abs(dot(getWorldNormalVector(), -getWorldViewVector()));
            float fresnel = mix(0.04, 1.0, pow(1.0 - NdotV, 5.0));
            fresnel *= materialParams.fresnelStrength;
            
            // Modulate base color with caustics and Fresnel
            material.baseColor.rgb *= 1.0 + causticPattern;
            material.baseColor.rgb += fresnel * vec3(0.3, 0.3, 0.5);
            
            // For high/ultra quality (refractionMode == 2.0), add chromatic dispersion
            if (materialParams.refractionMode > 1.5) {
                // Simulate chromatic dispersion with subtle RGB shift
                float dispersion = materialParams.chromaticDispersion * 0.02;
                material.baseColor.r *= 1.0 + dispersion;
                material.baseColor.b *= 1.0 - dispersion;
            }
            
            // Reduce roughness near edges for glass-like appearance
            material.roughness = mix(material.roughness, 0.01, fresnel * 0.3);
        }
        
        // Fake a tiny bit of subsurface scattering by tweaking ambient occlusion based on bump heights
        material.ambientOcclusion = clamp(1.0 - (abs(noise) * scale * 10.0), 0.5, 1.0);

        // Add subtle anisotropic sheen for marble-like materials
        material.anisotropy = 0.2 * noise;
    }
}
