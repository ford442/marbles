material {
    name : "Volcanic Magma Material",
    parameters : [
        { type : float3, name : baseColor },
        { type : float,  name : roughness },
        { type : float,  name : metallic },
        { type : float,  name : reflectance },
        { type : float,  name : clearCoat },
        { type : float,  name : clearCoatRoughness },
        { type : float,  name : bumpScale },
        { type : float,  name : bumpFrequency },
        { type : float,  name : lavaFlowSpeed },
        { type : float,  name : crackGlow },
        { type : float,  name : heatIntensity }
    ],
    requires : [ uv0, tangents ],
    shadingModel : lit,
    blending : opaque,
    specularAntiAliasing : true,
    specularAntiAliasingVariance : 0.15,
    specularAntiAliasingThreshold : 0.2
}

fragment {
    // Simplex noise
    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

    float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                           -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v -   i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                               + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                               dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }

    float fbm(vec2 uv, float freq) {
        float f = 0.0;
        float w = 0.5;
        for (int i = 0; i < 4; i++) {
            f += w * snoise(uv * freq);
            freq *= 2.0;
            w *= 0.5;
        }
        return f;
    }

    // Crust pattern with cracks
    float crustPattern(vec2 uv, vec3 worldPos) {
        float crust = 0.0;
        vec2 p1 = uv * 8.0;
        float c1 = sin(p1.x * 2.0 + sin(p1.y * 3.0)) * 0.5 + 0.5;
        c1 = smoothstep(0.55, 0.6, c1);
        crust += c1 * 0.6;

        vec2 p2 = uv * 15.0 + worldPos.xz * 0.5;
        float c2 = sin(p2.y * 3.0 + cos(p2.x * 2.0)) * sin(p2.x * 2.5);
        c2 = smoothstep(0.65, 0.7, c2 * 0.5 + 0.5) * 0.4;
        crust += c2;

        vec2 p3 = uv * 25.0;
        float c3 = sin(p3.x * 5.0) * cos(p3.y * 4.0) * 0.5 + 0.5;
        c3 = pow(c3, 8.0) * 0.2;
        crust += c3;

        return min(crust, 1.0);
    }

    // Animated lava flow through cracks
    vec3 lavaFlow(vec2 uv, vec3 worldPos, float time, float speed, float glow) {
        vec3 lava = vec3(0.0);
        vec2 flowDir = vec2(0.3, -1.0) * speed;
        vec2 flowUv = uv + flowDir * time;

        float turbulence = sin(flowUv.x * 10.0 + time * 2.0) *
                          cos(flowUv.y * 8.0 - time * 1.5) * 0.3;
        flowUv += vec2(turbulence);

        float l1 = sin(flowUv.x * 6.0) * cos(flowUv.y * 4.0 + time);
        l1 = l1 * 0.5 + 0.5;
        l1 = pow(l1, 2.0) * glow;
        lava += vec3(1.0, 0.4, 0.05) * l1;

        vec2 flowUv2 = uv * 1.5 + flowDir * time * 0.7 + vec2(0.5);
        float l2 = sin(flowUv2.x * 5.0 + time) * cos(flowUv2.y * 6.0);
        l2 = l2 * 0.5 + 0.5;
        l2 = pow(l2, 3.0) * glow * 0.7;
        lava += vec3(1.0, 0.15, 0.0) * l2;

        float hotSpot = sin(worldPos.x * 4.0 + worldPos.y * 3.0 + time * 0.5) * 0.5 + 0.5;
        hotSpot = pow(hotSpot, 4.0) * 0.5;
        lava += vec3(1.0, 0.6, 0.2) * hotSpot;

        return lava;
    }

    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        float freq = materialParams.bumpFrequency;
        float scale = materialParams.bumpScale;
        float time = getTime();

        // Procedural normal perturbation
        float noise = fbm(uv, freq);
        float noiseX = fbm(uv + vec2(0.01, 0.0), freq);
        float noiseY = fbm(uv + vec2(0.0, 0.01), freq);

        vec3 normalTangent;
        normalTangent.x = (noiseX - noise) * scale * 100.0;
        normalTangent.y = (noiseY - noise) * scale * 100.0;
        normalTangent.z = 1.0;
        normalTangent = normalize(normalTangent);
        material.normal = normalTangent;

        prepareMaterial(material);

        vec3 worldPos = getWorldPosition();
        float crust = crustPattern(uv, worldPos);
        vec3 lava = lavaFlow(uv, worldPos, time, materialParams.lavaFlowSpeed, materialParams.crackGlow);

        // Core pulse
        float dist = length(worldPos) * 2.0;
        float pulse = sin(time * 1.5) * 0.2 + 0.8;
        float core = exp(-dist * 2.0) * pulse;
        vec3 coreColor = vec3(1.0, 0.2, 0.0) * core * 1.5;

        // Fresnel heat glow at edges
        vec3 viewDir = normalize(getWorldCameraPosition() - worldPos);
        vec3 normal = normalize(shading_normal);
        float fresnel = pow(1.0 - abs(dot(viewDir, normal)), 3.0);
        vec3 heatGlow = vec3(1.0, 0.3, 0.05) * fresnel * 2.0 * materialParams.heatIntensity;

        // Combine base rock with lava
        vec3 rockColor = materialParams.baseColor;
        vec3 finalColor = rockColor * (1.0 - crust * 0.5);
        finalColor += lava;
        finalColor += coreColor;
        finalColor += heatGlow;

        // Emissive from lava and core
        vec3 emission = lava * 0.8 + coreColor * 0.6 + heatGlow * 0.5;

        material.baseColor = vec4(finalColor, 1.0);
        material.roughness = mix(0.9, 0.4, crust) + noise * 0.1;
        material.metallic = materialParams.metallic;
        material.reflectance = materialParams.reflectance;
        material.clearCoat = materialParams.clearCoat;
        material.clearCoatRoughness = materialParams.clearCoatRoughness;
        material.emissive = vec4(emission, 1.0);
        material.ambientOcclusion = clamp(1.0 - crust * 0.4, 0.5, 1.0);
    }
}
