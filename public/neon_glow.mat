material {
    name : "Neon Glow Material",
    parameters : [
        { type : float3, name : baseColor },
        { type : float,  name : roughness },
        { type : float,  name : metallic },
        { type : float,  name : reflectance },
        { type : float,  name : clearCoat },
        { type : float,  name : clearCoatRoughness },
        { type : float,  name : bumpScale },
        { type : float,  name : bumpFrequency },
        { type : float,  name : glowIntensity },
        { type : float,  name : iridescenceScale }
    ],
    requires : [ uv0, tangents ],
    shadingModel : lit,
    blending : opaque,
    specularAntiAliasing : true,
    specularAntiAliasingVariance : 0.15,
    specularAntiAliasingThreshold : 0.2
}

fragment {
    // Simplex noise
    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

    float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                           -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v -   i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                               + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                               dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }

    float fbm(vec2 uv, float freq) {
        float f = 0.0;
        float w = 0.5;
        for (int i = 0; i < 4; i++) {
            f += w * snoise(uv * freq);
            freq *= 2.0;
            w *= 0.5;
        }
        return f;
    }

    // Thin-film interference for iridescence
    vec3 thinFilmIridescence(float cosTheta, float d, float nFilm) {
        float delta = 2.0 * 3.14159 * nFilm * d * sqrt(1.0 - (1.0 - cosTheta * cosTheta) / (nFilm * nFilm));
        vec3 phase = vec3(delta, delta * 0.97, delta * 0.94);
        vec3 intensity = 0.5 + 0.5 * cos(phase);
        return intensity;
    }

    // Holographic circuit pattern
    float circuitPattern(vec2 uv, float time) {
        float circuit = 0.0;
        float angle = atan(uv.y - 0.5, uv.x - 0.5);
        float radius = length(uv - 0.5) * 20.0;
        circuit += sin(angle * 8.0 + radius * 2.0 + time) * 0.5 + 0.5;
        circuit *= exp(-abs(radius - 5.0) * 0.5);
        circuit *= exp(-abs(radius - 8.0) * 0.3);
        return circuit;
    }

    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        float freq = materialParams.bumpFrequency;
        float scale = materialParams.bumpScale;
        float time = getTime();

        // Normal perturbation
        float noise = fbm(uv, freq);
        float noiseX = fbm(uv + vec2(0.01, 0.0), freq);
        float noiseY = fbm(uv + vec2(0.0, 0.01), freq);
        vec3 normalTangent;
        normalTangent.x = (noiseX - noise) * scale * 100.0;
        normalTangent.y = (noiseY - noise) * scale * 100.0;
        normalTangent.z = 1.0;
        normalTangent = normalize(normalTangent);
        material.normal = normalTangent;

        prepareMaterial(material);

        vec3 worldPos = getWorldPosition();
        vec3 viewDir = normalize(getWorldCameraPosition() - worldPos);
        vec3 normal = normalize(shading_normal);

        // View-dependent iridescence
        float cosTheta = abs(dot(viewDir, normal));
        float filmThickness = 400.0 + sin(uv.x * 10.0 + uv.y * 8.0 + time) * 100.0;
        vec3 iridescence = thinFilmIridescence(cosTheta, filmThickness, 1.33);

        // Energy core glow (center of marble)
        float distFromCenter = length(uv - 0.5);
        float coreGlow = exp(-distFromCenter * 4.0) * materialParams.glowIntensity;
        float pulse = sin(time * 3.0) * 0.3 + 0.7;
        coreGlow *= pulse;

        // Circuit patterns on surface
        float circuit = circuitPattern(uv, time);

        // Neon colors
        vec3 neonCyan = vec3(0.0, 1.0, 1.0);
        vec3 neonPink = vec3(1.0, 0.0, 0.5);
        vec3 baseColor = mix(neonCyan, neonPink, sin(time) * 0.5 + 0.5);
        baseColor = mix(baseColor, vec3(0.5, 0.0, 1.0), iridescence.b);

        // Combine effects
        vec3 finalColor = baseColor * (0.3 + circuit * 0.5);
        finalColor += iridescence * materialParams.iridescenceScale;
        finalColor += baseColor * coreGlow;
        finalColor += neonCyan * circuit * 0.5;

        // Fresnel rim lighting
        float fresnel = pow(1.0 - cosTheta, 3.0);
        finalColor += baseColor * fresnel * 2.0;

        // Emission
        vec3 emission = finalColor * materialParams.glowIntensity;
        emission += baseColor * coreGlow * 2.0;
        emission += neonCyan * circuit * 0.3;

        material.baseColor = vec4(finalColor, 1.0);
        material.roughness = materialParams.roughness + noise * 0.1;
        material.metallic = materialParams.metallic;
        material.reflectance = materialParams.reflectance;
        material.clearCoat = materialParams.clearCoat;
        material.clearCoatRoughness = materialParams.clearCoatRoughness;
        material.emissive = vec4(emission, 1.0);
        material.anisotropy = 0.2 * noise;
    }
}
