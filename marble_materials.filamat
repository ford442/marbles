// ============================================================================
/*
material {
    name : StoneVein,
    requires : [
        position,
        normal,
        uv0
    ],
    shadingModel : lit,
    blending : opaque,
    depthWrite : true,
    culling : back,
    subsurfaceScattering : true,
    
    parameters : [
        { type : float,  name : uTime },
        { type : float,  name : uSSSIntensity },
        { type : float,  name : uSparkleDensity },
        { type : float,  name : uSparkleSpeed },
        { type : sampler2d, name : veinTexture },
        { type : sampler2d, name : sparkleTexture },
        { type : samplerCubemap, name : envMap }
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        vec3 normal = normalize(getWorldGeometricNormalVector());
        vec3 viewDir = normalize(getWorldViewVector());
        vec2 uv = getUV0();
        
        // Procedural vein pattern
        vec2 p = uv * 3.0;
        float vein1 = sin(p.x * 2.0 + sin(p.y * 3.0 + materialParams.uTime * 0.1)) * 0.5 + 0.5;
        vein1 = smoothstep(0.6, 0.65, vein1);
        
        float vein2 = sin(p.y * 4.0 + sin(p.x * 2.0 - materialParams.uTime * 0.05)) * 0.5 + 0.5;
        vein2 = smoothstep(0.7, 0.75, vein2) * 0.5;
        
        float veins = vein1 + vein2;
        
        // Stone colors
        vec3 baseStone = vec3(0.85, 0.82, 0.78);
        vec3 veinColor = vec3(0.3, 0.25, 0.35);
        vec3 stoneColor = mix(baseStone, veinColor, veins);
        
        // Subsurface scattering
        float thickness = 1.0 - veins * 0.7;
        material.subsurfaceColor = vec3(1.0, 0.85, 0.7) * materialParams.uSSSIntensity;
        material.subsurfacePower = thickness * 10.0;
        material.subsurfaceThickness = thickness;
        
        // Roughness variation
        float roughness = mix(0.4, 0.8, veins);
        
        // Ambient occlusion in veins
        float ao = 1.0 - veins * 0.3;
        stoneColor *= ao;
        
        material.baseColor = vec4(stoneColor, 1.0);
        material.roughness = roughness;
        material.metallic = 0.0;
    }
}
*/

