/*
// Motion Blur
material {
    name : MotionBlur,
    parameters : [
        { type : sampler2d, name : colorTexture },
        { type : sampler2d, name : velocityTexture },
        { type : int, name : sampleCount },
        { type : float, name : intensity }
    ],
    vertexDomain : device,
    shadingModel : unlit,
    depthWrite : false
}

fragment {
    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        vec2 velocity = texture(materialParams.velocityTexture, uv).rg * materialParams.intensity;
        
        vec3 result = vec3(0.0);
        float totalWeight = 0.0;
        
        for (int i = 0; i < materialParams.sampleCount; i++) {
            float t = float(i) / float(materialParams.sampleCount - 1);
            vec2 sampleUV = uv + velocity * (t - 0.5);
            float weight = 1.0 - abs(t - 0.5) * 2.0;
            result += texture(materialParams.colorTexture, sampleUV).rgb * weight;
            totalWeight += weight;
        }
        
        material.baseColor = vec4(result / totalWeight, 1.0);
    }
}
*/

