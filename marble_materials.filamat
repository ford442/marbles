// ============================================================================
// MATERIAL: Neon Glow Marble
// ============================================================================
/*
material {
    name : NeonGlow,
    requires : [
        position,
        normal,
        uv0
    ],
    shadingModel : unlit,  // Full emission
    blending : additive,
    depthWrite : false,
    culling : back,
    
    parameters : [
        { type : float,  name : uTime },
        { type : float,  name : uIridescenceScale },
        { type : float,  name : uGlowIntensity },
        { type : float,  name : uHologramSpeed },
        { type : float,  name : uDistortionStrength },
        { type : sampler2d, name : hologramTexture },
        { type : sampler2d, name : noiseTexture },
        { type : samplerCubemap, name : envMap }
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        vec3 normal = normalize(getWorldGeometricNormalVector());
        vec3 viewDir = normalize(getWorldViewVector());
        vec2 uv = getUV0();
        
        // Thin-film iridescence
        float cosTheta = abs(dot(viewDir, normal));
        float filmThickness = 400.0 + sin(uv.x * 10.0 + uv.y * 8.0 + materialParams.uTime) * 100.0;
        vec3 phase = vec3(
            filmThickness,
            filmThickness * 0.97,
            filmThickness * 0.94
        );
        vec3 iridescence = 0.5 + 0.5 * cos(phase * 0.01);
        
        // Core glow
        float distFromCenter = length(uv - 0.5);
        float coreGlow = exp(-distFromCenter * 4.0) * materialParams.uGlowIntensity;
        float pulse = sin(materialParams.uTime * 3.0) * 0.3 + 0.7;
        coreGlow *= pulse;
        
        // Neon colors
        vec3 neonCyan = vec3(0.0, 1.0, 1.0);
        vec3 neonPink = vec3(1.0, 0.0, 0.5);
        vec3 baseColor = mix(neonCyan, neonPink, sin(materialParams.uTime) * 0.5 + 0.5);
        
        // Combine
        vec3 finalColor = baseColor * (0.3 + coreGlow);
        finalColor += iridescence * materialParams.uIridescenceScale;
        
        // Rim lighting
        float fresnel = pow(1.0 - cosTheta, 3.0);
        finalColor += baseColor * fresnel * 2.0;
        
        material.baseColor = vec4(finalColor, 0.95);
        material.emissive = vec4(finalColor * materialParams.uGlowIntensity, 1.0);
    }
}
*/

