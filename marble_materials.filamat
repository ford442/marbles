/*
// Screen Space Reflections
material {
    name : SSR,
    parameters : [
        { type : sampler2d, name : colorTexture },
        { type : sampler2d, name : depthTexture },
        { type : sampler2d, name : normalTexture },
        { type : float4x4, name : viewMatrix },
        { type : float4x4, name : projMatrix },
        { type : int, name : maxSteps },
        { type : float, name : stepSize },
        { type : float, name : thickness }
    ],
    vertexDomain : device,
    shadingModel : unlit,
    depthWrite : false
}

fragment {
    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        float depth = texture(materialParams.depthTexture, uv).r;
        
        // Reconstruct world position
        vec4 clipPos = vec4(uv * 2.0 - 1.0, depth, 1.0);
        vec4 viewPos = inverse(materialParams.projMatrix) * clipPos;
        viewPos /= viewPos.w;
        vec3 worldPos = (inverse(materialParams.viewMatrix) * viewPos).xyz;
        
        // Get normal
        vec3 normal = texture(materialParams.normalTexture, uv).xyz * 2.0 - 1.0;
        normal = normalize(mat3(materialParams.viewMatrix) * normal);
        
        // Calculate reflection ray
        vec3 viewDir = normalize(viewPos.xyz);
        vec3 reflectDir = reflect(viewDir, normal);
        
        // Ray march in view space
        vec3 rayPos = viewPos.xyz;
        vec3 rayDir = reflectDir;
        
        vec4 reflectionColor = vec4(0.0);
        
        for (int i = 0; i < materialParams.maxSteps; i++) {
            rayPos += rayDir * materialParams.stepSize;
            
            // Project to screen space
            vec4 projPos = materialParams.projMatrix * vec4(rayPos, 1.0);
            projPos.xy /= projPos.w;
            projPos.xy = projPos.xy * 0.5 + 0.5;
            
            if (projPos.x < 0.0 || projPos.x > 1.0 || 
                projPos.y < 0.0 || projPos.y > 1.0) {
                break;
            }
            
            float sceneDepth = texture(materialParams.depthTexture, projPos.xy).r;
            float sceneZ = -(inverse(materialParams.projMatrix) * 
                            vec4(projPos.xy * 2.0 - 1.0, sceneDepth, 1.0)).w;
            
            if (rayPos.z > sceneZ && rayPos.z < sceneZ + materialParams.thickness) {
                reflectionColor = texture(materialParams.colorTexture, projPos.xy);
                break;
            }
        }
        
        vec3 baseColor = texture(materialParams.colorTexture, uv).rgb;
        float fresnel = pow(1.0 - abs(dot(-viewDir, normal)), 2.0);
        
        material.baseColor = vec4(mix(baseColor, reflectionColor.rgb, fresnel * reflectionColor.a), 1.0);
    }
}
*/
