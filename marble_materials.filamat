// Chromatic Aberration
material {
    name : ChromaticAberration,
    parameters : [
        { type : sampler2d, name : source },
        { type : float, name : intensity }
    ],
    vertexDomain : device,
    shadingModel : unlit,
    depthWrite : false
}

fragment {
    void material(inout MaterialInputs material) {
        vec2 uv = getUV0();
        vec2 center = vec2(0.5, 0.5);
        vec2 direction = uv - center;
        float dist = length(direction);
        vec2 offset = direction * materialParams.intensity * dist;
        
        float r = texture(materialParams.source, uv + offset * 1.0).r;
        float g = texture(materialParams.source, uv + offset * 0.5).g;
        float b = texture(materialParams.source, uv).b;
        
        material.baseColor = vec4(r, g, b, 1.0);
    }
}
