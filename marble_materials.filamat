        { type : float,  name : uDistortionStrength },
        { type : sampler2d, name : noiseTexture },
        { type : samplerCubemap, name : envMap },
        { type : float4, name : materialBaseColor }
    ],
    
    variables : [
        { name : worldPosition, precision : high },
        { name : normal, precision : high },
        { name : viewDirection, precision : high },
        { name : uv, precision : medium }
    ]
}

fragment {
    #include "common_types.glsl"
    
    void material(inout MaterialInputs material) {
        vec3 normal = normalize(getWorldGeometricNormalVector());
        vec3 viewDir = normalize(getWorldViewVector());
        
        // Fresnel effect
        float fresnel = pow(1.0 - abs(dot(viewDir, normal)), materialParams.uFresnelPower);
        
        // Caustic simulation
        vec3 internalPos = getWorldPosition() * 0.5 + vec3(0.0, materialParams.uTime * 0.1, 0.0);
        float caustic = 0.0;
        caustic += sin(internalPos.x * 3.0 + materialParams.uTime) * cos(internalPos.y * 3.0 + materialParams.uTime * 0.7);
        caustic = pow(caustic * 0.5 + 0.5, 3.0) * materialParams.uCausticIntensity;
        
        // Environment sampling (simplified - actual would use proper reflection/refraction)
        vec3 reflectDir = reflect(-viewDir, normal);
        vec4 reflectionColor = sampleMaterial(envMap, reflectDir);
        
        // Glass base with caustics
        vec3 glassColor = reflectionColor.rgb;
        glassColor += vec3(1.0, 0.95, 0.8) * caustic * (1.0 - fresnel);
        
        // Mix with base material color
        glassColor = mix(glassColor, materialParams.materialBaseColor.rgb, 
                        materialParams.materialBaseColor.a * 0.3);
        
        material.baseColor = vec4(glassColor, 0.85 + fresnel * 0.15);
        material.roughness = 0.05;
        material.metallic = 0.0;
    }
}

vertex {
    void materialVertex(inout MaterialVertexInputs material) {
        // Pass world position to fragment
        material.worldPosition = getWorldPosition();
    }
}
*/

// ============================================================================
// MATERIAL: Obsidian Metal Marble
