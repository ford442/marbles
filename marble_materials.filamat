/**
 * Filament Material Definitions (.mat format)
 * These are compiled to .filamat binaries using matc (Filament material compiler)
 * 
 * Compilation: matc -o marble_glass.filamat marble_glass.mat
 */

// ============================================================================
// MATERIAL: Classic Glass Marble
// ============================================================================
/*
material {
    name : ClassicGlass,
    requires : [
        position,
        normal,
        tangent,
        uv0
    ],
    shadingModel : unlit,  // Custom lighting in shader
    blending : transparent,
    depthWrite : false,
    culling : back,
    
    parameters : [
        { type : float,  name : uTime },
